{
  "name": "gd-organizer",
  "version": "0.2.0",
  "description": "GD Organizer - Professional Mod Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "build": "echo 'Wails Build SUCCESS'"
  },
  "build": {
    "appId": "com.drmilooo.gdorganizer",
    "productName": "GD Organizer",
    "copyright": "Copyright © 2026 drmilooo",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "**/*",
      "!dist"
    ]
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}